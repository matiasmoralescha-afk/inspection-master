# Gmail OAuth token (generated once locally via auth_setup.py)
GMAIL_TOKEN_FILE=credentials/gmail-token.json

# Google Sheets — service account (share the sheet with this account's email)
GOOGLE_SERVICE_ACCOUNT_FILE=credentials/google-service-account.json

# Target Google Sheet (new sheet for pilot — not the ChatGPT-contaminated one)
SHEET_ID=REPLACE_WITH_NEW_SHEET_ID

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# SQLite database
DB_PATH=data/inspection_agent.db

# Gmail search query for Alpine Fresh Ocean Reports
# Real subject format: "ALPINE FRESH | ASPARAGUS OCEAN REPORT on 06/19/26 @ 1710"
ALPINE_OCEAN_GMAIL_QUERY=subject:"OCEAN REPORT" subject:"ALPINE" newer_than:7d
